# TMDB API key (required): https://www.themoviedb.org/settings/api
# Both the short key (v3) and the long token (v4, "Read Access Token") work.
TMDB_API_KEY=

# SQLite database path (optional, default: ./data/tvtime.db)
# DATABASE_PATH=./data/tvtime.db

# Country for the "Where to watch" streaming platforms (optional, default: FR)
# WATCH_REGION=FR

# Docker deployment: exact URL used to access the app
# (e.g. http://192.168.1.10:3000). Required for form submissions to work.
# ORIGIN=
