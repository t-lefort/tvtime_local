# Clé API TMDB (obligatoire) : https://www.themoviedb.org/settings/api
# La clé courte (v3) et le jeton long (v4, "Read Access Token") fonctionnent tous les deux.
TMDB_API_KEY=

# Mot de passe de connexion (optionnel : laisser vide pour désactiver l'authentification)
AUTH_PASSWORD=

# Chemin de la base SQLite (optionnel, défaut : ./data/tvtime.db)
# DATABASE_PATH=./data/tvtime.db

# En déploiement Docker : URL exacte par laquelle vous accédez à l'app
# (ex. http://192.168.1.10:3000). Requis pour que les formulaires fonctionnent.
# ORIGIN=
